{
  "name": "axiom-landing-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Landing v2 dev server: npm run dev → http://localhost:3030 (port 3000 is for the Axiom subscription app).",
  "scripts": {
    "dev:unlock": "node -e \"try{require('fs').unlinkSync('.next/dev/lock')}catch(e){}\"",
    "dev": "next dev -H 0.0.0.0 -p 3030",
    "dev:host": "next dev -H 0.0.0.0 -p 3030",
    "dev:alt": "next dev -H 0.0.0.0 -p 3020",
    "build": "next build",
    "start": "next start",
    "start:local": "next start -H 0.0.0.0 -p 3030",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
